{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DisplayType",
  "description": "Hardware template for an eInk display device",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for this display type",
      "readOnly": true
    },
    "name": {
      "type": "string",
      "description": "Human readable name for the hardware"
    },
    "width_mm": {
      "type": "integer",
      "minimum": 1,
      "description": "Frame outer width"
    },
    "height_mm": {
      "type": "integer",
      "minimum": 1,
      "description": "Frame outer height"
    },
    "panel_width_mm": {
      "type": "integer",
      "minimum": 1,
      "description": "Display panel active area width"
    },
    "panel_height_mm": {
      "type": "integer",
      "minimum": 1,
      "description": "Display panel active area height"
    },
    "width_px": {
      "type": "integer",
      "minimum": 1
    },
    "height_px": {
      "type": "integer",
      "minimum": 1
    },
    "colour_type": {
      "type": "string",
      "enum": ["MONO", "BWR", "BWY", "BWRY", "BWGBRY", "GRAYSCALE_4"]
    },
    "frame": {
      "type": "object",
      "properties": {
        "border_width_mm": {
          "type": "integer",
          "minimum": 0
        },
        "colour": {
          "type": "string",
          "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$"
        }
      },
      "required": ["border_width_mm", "colour"]
    },
    "mat": {
      "type": "object",
      "properties": {
        "colour": {
          "type": "string",
          "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$"
        }
      },
      "required": ["colour"]
    }
  },
  "required": ["id", "name", "width_mm", "height_mm", "panel_width_mm", "panel_height_mm", "width_px", "height_px", "colour_type", "frame", "mat"]
}
