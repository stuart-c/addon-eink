{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ImageListResponse",
  "type": "object",
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "readOnly": true },
          "name": { "type": "string", "readOnly": true },
          "artist": { "type": ["string", "null"], "readOnly": true },
          "collection": { "type": ["string", "null"], "readOnly": true },
          "description": { "type": ["string", "null"], "readOnly": true },
          "file_type": { "type": "string", "readOnly": true },
          "dimensions": {
            "type": "object",
            "readOnly": true,
            "properties": {
              "width": { "type": "integer", "readOnly": true },
              "height": { "type": "integer", "readOnly": true }
            },
            "required": ["width", "height"]
          }
        },
        "required": ["id", "name", "file_type", "dimensions"]
      }
    },
    "pagination": {
      "type": "object",
      "readOnly": true,
      "properties": {
        "page": { "type": "integer", "minimum": 1, "readOnly": true },
        "limit": { "type": "integer", "minimum": 1, "readOnly": true },
        "total_items": { "type": "integer", "minimum": 0, "readOnly": true },
        "total_pages": { "type": "integer", "minimum": 0, "readOnly": true }
      },
      "required": ["page", "limit", "total_items", "total_pages"]
    }
  },
  "required": ["items", "pagination"]
}
