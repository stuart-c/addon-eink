{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Layout",
  "description": "An arrangement of eInk displays on a grid",
  "type": "object",
  "properties": {
    "id": { "$ref": "common.json#/definitions/id" },
    "name": { "$ref": "common.json#/definitions/name" },
    "canvas_width_mm": { "$ref": "common.json#/definitions/positive_integer" },
    "canvas_height_mm": { "$ref": "common.json#/definitions/positive_integer" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "display_type_id": { "type": "string" },
          "x_mm": { "$ref": "common.json#/definitions/non_negative_integer" },
          "y_mm": { "$ref": "common.json#/definitions/non_negative_integer" },
          "orientation": { "$ref": "common.json#/definitions/orientation" },
          "device_id": { "type": "string" }
        },
        "required": ["display_type_id", "x_mm", "y_mm", "orientation"]
      }
    }
  },
  "required": ["name", "canvas_width_mm", "canvas_height_mm", "items"]
}
