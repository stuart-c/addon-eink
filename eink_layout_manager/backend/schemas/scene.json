{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Scene",
  "description": "A complex scene combining layouts, images and live data",
  "type": "object",
  "properties": {
    "id": {
      "allOf": [
        { "$ref": "common.json#/definitions/id" },
        { "description": "Unique identifier for this scene" }
      ]
    },
    "name": {
      "allOf": [
        { "$ref": "common.json#/definitions/name" },
        { "description": "Human readable name for the scene" }
      ]
    },
    "layout": {
      "type": "string",
      "description": "ID of the layout used by this scene",
      "readOnly": true
    },
    "status": {
      "type": "string",
      "description": "Current status of the scene",
      "enum": ["draft", "active"],
      "readOnly": true,
      "default": "draft"
    },
    "items": {
      "type": "array",
      "description": "List of components in the scene",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for this component within the scene"
          },
          "type": {
            "type": "string",
            "enum": ["image", "tile"]
          },
          "displays": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "images": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "image_id": {
                  "type": "string"
                },
                "scaling_factor": {
                  "type": "number",
                  "minimum": 0
                },
                "offset": {
                  "type": "object",
                  "properties": {
                    "x": { "type": "number" },
                    "y": { "type": "number" }
                  },
                  "required": ["x", "y"]
                }
              },
              "required": ["image_id", "scaling_factor", "offset"]
            }
          }
        },
        "required": ["id", "type", "displays", "images"]
      }
    }
  },
  "required": [
    "name",
    "layout"
  ]
}
