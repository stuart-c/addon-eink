{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Image",
  "description": "Metadata for an image file used in layouts",
  "type": "object",
  "properties": {
    "id": { "$ref": "common.json#/definitions/id" },
    "name": { "$ref": "common.json#/definitions/name" },
    "artist": {
      "type": ["string", "null"],
      "description": "The creator of the image"
    },
    "collection": {
      "type": ["string", "null"],
      "description": "The collection this image belongs to"
    },
    "file_type": {
      "type": "string",
      "description": "Image file format",
      "enum": ["JPG", "JPEG", "PNG", "GIF", "WEBP", "BMP", "TIFF"],
      "readOnly": true
    },
    "dimensions": {
      "allOf": [
        { "$ref": "common.json#/definitions/dimensions_px" },
        { "readOnly": true }
      ]
    },
    "colour_depth": {
      "type": ["integer", "null"],
      "minimum": 1,
      "description": "Bits per pixel",
      "readOnly": true
    },
    "keywords": {
      "type": ["array", "null"],
      "items": {
        "type": "string"
      },
      "description": "List of tags associated with the image"
    },
    "description": {
      "type": ["string", "null"],
      "description": "Long-form description of the image content"
    },
    "original_archive_file": {
      "type": ["string", "null"],
      "description": "Name of the original archive if imported"
    },
    "license": {
      "type": ["string", "null"],
      "description": "Usage license (e.g., CC BY-SA 4.0)"
    },
    "source": {
      "type": ["string", "null"],
      "description": "Original source URL or repository"
    },
    "status": {
      "type": "string",
      "description": "Processing status of the image",
      "enum": ["UPLOADED", "PROCESSING", "READY", "ERROR"],
      "readOnly": true
    },
    "conversion": {
      "type": ["object", "null"],
      "description": "Optional configuration for image conversion using edpoptimize",
      "properties": {
        "ditheringType": {
          "type": "string",
          "enum": ["errorDiffusion", "ordered", "random", "quantizationOnly"],
          "default": "errorDiffusion"
        },
        "errorDiffusionMatrix": {
          "type": "string",
          "enum": ["floydSteinberg", "falseFloydSteinberg", "jarvis", "stucki", "burkes", "sierra3", "sierra2", "sierra2-4a"],
          "default": "floydSteinberg"
        },
        "serpentine": {
          "type": "boolean",
          "default": false
        },
        "orderedDitheringType": {
          "type": "string",
          "enum": ["bayer"],
          "default": "bayer"
        },
        "orderedDitheringMatrix": {
          "type": "array",
          "items": { "type": "integer" },
          "minItems": 2,
          "maxItems": 2,
          "default": [4, 4]
        },
        "randomDitheringType": {
          "type": "string",
          "enum": ["blackAndWhite", "rgb"],
          "default": "blackAndWhite"
        },
        "palette": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" } }
          ],
          "default": "default"
        },
        "sampleColoursFromImage": {
          "type": "boolean",
          "default": false
        },
        "numberOfSampleColours": {
          "type": "integer",
          "minimum": 1,
          "default": 10
        }
      }
    }
  },
  "required": [
    "id",
    "name",
    "file_type",
    "dimensions"
  ]
}
