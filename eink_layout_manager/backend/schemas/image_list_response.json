{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ImageListResponse",
  "type": "object",
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "$ref": "common.json#/definitions/id" },
          "name": { "$ref": "common.json#/definitions/name" },
          "artist": { "type": ["string", "null"], "readOnly": true },
          "collection": { "type": ["string", "null"], "readOnly": true },
          "description": { "type": ["string", "null"], "readOnly": true },
          "file_type": { "type": "string", "readOnly": true },
          "dimensions": {
            "allOf": [
              { "$ref": "common.json#/definitions/dimensions_px" },
              { "readOnly": true }
            ]
          }
        },
        "required": ["id", "name", "file_type", "dimensions"]
      }
    },
    "pagination": {
      "$ref": "pagination.json"
    }
  },
  "required": ["items", "pagination"]
}
