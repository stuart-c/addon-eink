{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DisplayType",
  "description": "Hardware template for an eInk display device",
  "type": "object",
  "properties": {
    "id": { "$ref": "common.json#/definitions/id" },
    "name": { "$ref": "common.json#/definitions/name" },
    "width_mm": {
      "allOf": [
        { "$ref": "common.json#/definitions/positive_integer" },
        { "description": "Frame outer width" }
      ]
    },
    "height_mm": {
      "allOf": [
        { "$ref": "common.json#/definitions/positive_integer" },
        { "description": "Frame outer height" }
      ]
    },
    "panel_width_mm": {
      "allOf": [
        { "$ref": "common.json#/definitions/positive_integer" },
        { "description": "Display panel active area width" }
      ]
    },
    "panel_height_mm": {
      "allOf": [
        { "$ref": "common.json#/definitions/positive_integer" },
        { "description": "Display panel active area height" }
      ]
    },
    "width_px": { "$ref": "common.json#/definitions/positive_integer" },
    "height_px": { "$ref": "common.json#/definitions/positive_integer" },
    "colour_type": {
      "type": "string",
      "enum": ["MONO", "BWR", "BWY", "BWRY", "BWGBRY", "GRAYSCALE_4"]
    },
    "frame": {
      "type": "object",
      "properties": {
        "border_width_mm": { "$ref": "common.json#/definitions/non_negative_integer" },
        "colour": { "$ref": "common.json#/definitions/hex_color" }
      },
      "required": ["border_width_mm", "colour"]
    },
    "mat": {
      "type": "object",
      "properties": {
        "colour": { "$ref": "common.json#/definitions/hex_color" }
      },
      "required": ["colour"]
    },
    "pixel_width_mm": {
      "type": "number",
      "readOnly": true,
      "description": "Calculated pixel width in mm"
    },
    "pixel_height_mm": {
      "type": "number",
      "readOnly": true,
      "description": "Calculated pixel height in mm"
    }
  },
  "required": ["name", "width_mm", "height_mm", "panel_width_mm", "panel_height_mm", "width_px", "height_px", "colour_type", "frame", "mat"]
}
